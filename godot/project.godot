2d_physics/layer_2="Enemy Physics"
2d_physics/layer_3="Wall"
2d_physics/layer_4="Player Hitbox"
2d_physics/layer_5="Player Hurtbox"
2d_physics/layer_6="Enemy Hitbox"
2d_physics/layer_7="Enemy Hurtbox"
2d_physics/layer_8="Projectile"
2d_physics/layer_9="Detection"
