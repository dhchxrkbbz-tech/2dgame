; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be manually edited.

config_version=5

[application]

config/name="Ashenfall"
config/description="2D Top-Down Dark Fantasy Action RPG"
config/version="0.1.0"
run/main_scene="res://scenes/main/game_world.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Constants="*res://scripts/core/constants.gd"
EventBus="*res://scripts/core/event_bus.gd"
GameManager="*res://scripts/core/game_manager.gd"
InputManager="*res://scripts/core/input_manager.gd"
AudioManager="*res://scripts/core/audio_manager.gd"
SceneManager="*res://scripts/core/scene_manager.gd"
SaveManager="*res://scripts/core/save_manager.gd"
WorldManager="*res://scripts/world/world_manager.gd"
EconomyManager="*res://scripts/economy/economy_manager.gd"
NetworkManager="*res://scripts/multiplayer/network_manager.gd"
LootManager="*res://scripts/items/loot_manager.gd"
QuestManager="*res://scripts/quest/quest_manager.gd"
DialogueManager="*res://scripts/dialogue/dialogue_manager.gd"
TutorialManager="*res://scripts/tutorial/tutorial_manager.gd"
StatsTracker="*res://scripts/progression/stats_tracker.gd"
AchievementManager="*res://scripts/progression/achievement_manager.gd"
WorldEventManager="*res://scripts/progression/world_event_manager.gd"
EndgameManager="*res://scripts/progression/endgame_manager.gd"
FastTravel="*res://scripts/progression/fast_travel.gd"
AccessibilityManager="*res://scripts/core/accessibility_manager.gd"
LocalizationManager="*res://scripts/core/localization_manager.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="viewport"
window/stretch/aspect="keep"

