[gd_scene load_steps=2 format=3 uid="uid://statsscr01"]

[sub_resource type="GDScript" id="GDScript_stats"]
script/source = "## StatsScreen - Játékos statisztikák megjelenítése
## Kategóriánként csoportosított listás formátum
extends Control

var _tab_container: TabContainer = null
var _close_button: Button = null


func _ready() -> void:
	# Teljes képernyő
	set_anchors_preset(Control.PRESET_FULL_RECT)
	
	# Sötét háttér
	var bg := ColorRect.new()
	bg.set_anchors_preset(Control.PRESET_FULL_RECT)
	bg.color = Color(0.02, 0.02, 0.05, 0.9)
	add_child(bg)
	
	# Fő panel
	var panel := PanelContainer.new()
	panel.set_anchors_preset(Control.PRESET_CENTER)
	panel.position = Vector2(40, 20)
	panel.size = Vector2(560, 320)
	
	var style := StyleBoxFlat.new()
	style.bg_color = Color(0.08, 0.07, 0.12, 0.95)
	style.border_color = Color(0.3, 0.25, 0.4)
	style.set_border_width_all(1)
	style.set_corner_radius_all(4)
	style.content_margin_left = 8
	style.content_margin_right = 8
	style.content_margin_top = 8
	style.content_margin_bottom = 8
	panel.add_theme_stylebox_override(\"panel\", style)
	add_child(panel)
	
	# VBox a panel-ben
	var vbox := VBoxContainer.new()
	vbox.add_theme_constant_override(\"separation\", 4)
	panel.add_child(vbox)
	
	# Cím
	var title := Label.new()
	title.text = \"STATISTICS\"
	title.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	title.add_theme_font_size_override(\"font_size\", 14)
	title.add_theme_color_override(\"font_color\", Color(0.9, 0.8, 0.5))
	vbox.add_child(title)
	
	# Tab container
	_tab_container = TabContainer.new()
	_tab_container.custom_minimum_size = Vector2(540, 250)
	vbox.add_child(_tab_container)
	
	# Close gomb
	_close_button = Button.new()
	_close_button.text = \"Close [ESC]\"
	_close_button.custom_minimum_size = Vector2(80, 24)
	_close_button.pressed.connect(_close)
	vbox.add_child(_close_button)
	
	# Adatok betöltése
	_populate_tabs()


func _populate_tabs() -> void:
	if not has_node(\"/root/StatsTracker\"):
		return
	
	var all_stats: Dictionary = StatsTracker.get_all_stats()
	
	var tab_names: Dictionary = {
		\"combat\": \"Combat\",
		\"economy\": \"Economy\",
		\"exploration\": \"Exploration\",
		\"loot\": \"Loot\",
		\"multiplayer\": \"Multiplayer\",
		\"general\": \"General\",
	}
	
	for category_key in [\"combat\", \"economy\", \"exploration\", \"loot\", \"multiplayer\", \"general\"]:
		var scroll := ScrollContainer.new()
		scroll.name = tab_names.get(category_key, category_key)
		scroll.custom_minimum_size = Vector2(520, 220)
		
		var stat_vbox := VBoxContainer.new()
		stat_vbox.add_theme_constant_override(\"separation\", 2)
		scroll.add_child(stat_vbox)
		
		var stats: Dictionary = all_stats.get(category_key, {})
		for stat_name in stats:
			var row := HBoxContainer.new()
			row.add_theme_constant_override(\"separation\", 8)
			
			var name_label := Label.new()
			name_label.text = stat_name
			name_label.custom_minimum_size = Vector2(250, 14)
			name_label.add_theme_font_size_override(\"font_size\", 8)
			name_label.add_theme_color_override(\"font_color\", Color(0.7, 0.7, 0.7))
			row.add_child(name_label)
			
			var value_label := Label.new()
			value_label.text = str(stats[stat_name])
			value_label.add_theme_font_size_override(\"font_size\", 8)
			value_label.add_theme_color_override(\"font_color\", Color(0.9, 0.85, 0.6))
			row.add_child(value_label)
			
			stat_vbox.add_child(row)
		
		_tab_container.add_child(scroll)
	
	# Achievement összefoglaló tab
	_add_achievement_tab()


func _add_achievement_tab() -> void:
	if not has_node(\"/root/AchievementManager\"):
		return
	
	var scroll := ScrollContainer.new()
	scroll.name = \"Achievements\"
	scroll.custom_minimum_size = Vector2(520, 220)
	
	var ach_vbox := VBoxContainer.new()
	ach_vbox.add_theme_constant_override(\"separation\", 2)
	scroll.add_child(ach_vbox)
	
	# Összefoglaló
	var summary := Label.new()
	summary.text = \"Unlocked: %d / %d (%.1f%%)\" % [
		AchievementManager.get_unlocked_count(),
		AchievementManager.get_total_count(),
		AchievementManager.get_completion_percentage(),
	]
	summary.add_theme_font_size_override(\"font_size\", 9)
	summary.add_theme_color_override(\"font_color\", Color(0.9, 0.8, 0.3))
	ach_vbox.add_child(summary)
	
	var de_earned := Label.new()
	de_earned.text = \"Total Dark Essence Earned: %d\" % AchievementManager.get_total_de_earned()
	de_earned.add_theme_font_size_override(\"font_size\", 8)
	de_earned.add_theme_color_override(\"font_color\", Color(0.6, 0.3, 0.9))
	ach_vbox.add_child(de_earned)
	
	# Separator
	var sep := HSeparator.new()
	ach_vbox.add_child(sep)
	
	# Achievement lista kategóriánként
	for category in Enums.AchievementCategory.values():
		var cat_name: String = Enums.AchievementCategory.keys()[category]
		var achievements := AchievementManager.get_achievements_by_category(category)
		
		if achievements.is_empty():
			continue
		
		var cat_label := Label.new()
		cat_label.text = \"── %s ──\" % cat_name
		cat_label.add_theme_font_size_override(\"font_size\", 9)
		cat_label.add_theme_color_override(\"font_color\", Color(0.8, 0.6, 0.3))
		ach_vbox.add_child(cat_label)
		
		for ach in achievements:
			var ui_data := ach.to_ui_dict()
			var row := HBoxContainer.new()
			row.add_theme_constant_override(\"separation\", 4)
			
			# Státusz ikon
			var status := Label.new()
			status.text = \"✓\" if ui_data[\"is_unlocked\"] else \"○\"
			status.add_theme_font_size_override(\"font_size\", 8)
			status.add_theme_color_override(\"font_color\",
				Color(0.3, 0.9, 0.3) if ui_data[\"is_unlocked\"] else Color(0.5, 0.5, 0.5))
			row.add_child(status)
			
			# Név
			var name_lbl := Label.new()
			name_lbl.text = ui_data[\"name\"]
			name_lbl.custom_minimum_size = Vector2(130, 14)
			name_lbl.add_theme_font_size_override(\"font_size\", 7)
			name_lbl.add_theme_color_override(\"font_color\",
				Color(0.9, 0.85, 0.6) if ui_data[\"is_unlocked\"] else Color(0.6, 0.6, 0.6))
			row.add_child(name_lbl)
			
			# Leírás
			var desc_lbl := Label.new()
			desc_lbl.text = ui_data[\"description\"]
			desc_lbl.custom_minimum_size = Vector2(200, 14)
			desc_lbl.add_theme_font_size_override(\"font_size\", 7)
			desc_lbl.add_theme_color_override(\"font_color\", Color(0.5, 0.5, 0.5))
			row.add_child(desc_lbl)
			
			# Haladás
			var prog_lbl := Label.new()
			if ui_data[\"is_unlocked\"]:
				prog_lbl.text = \"Done\"
				prog_lbl.add_theme_color_override(\"font_color\", Color(0.3, 0.9, 0.3))
			elif not ui_data[\"is_hidden\"]:
				prog_lbl.text = \"%d/%d\" % [ui_data[\"progress\"], ui_data[\"target\"]]
				prog_lbl.add_theme_color_override(\"font_color\", Color(0.7, 0.7, 0.7))
			else:
				prog_lbl.text = \"???\"
				prog_lbl.add_theme_color_override(\"font_color\", Color(0.4, 0.4, 0.4))
			prog_lbl.add_theme_font_size_override(\"font_size\", 7)
			row.add_child(prog_lbl)
			
			ach_vbox.add_child(row)
	
	_tab_container.add_child(scroll)


func _unhandled_input(event: InputEvent) -> void:
	if event.is_action_pressed(\"pause\") or event.is_action_pressed(\"ui_cancel\"):
		_close()
		get_viewport().set_input_as_handled()


func _close() -> void:
	EventBus.screen_closed.emit(\"stats_screen\")
	queue_free()
"

[node name="StatsScreen" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = SubResource("GDScript_stats")
